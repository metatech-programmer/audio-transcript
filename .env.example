# Transcription API (Choose one)
# Option 1: Groq Whisper API (Recommended)
GROQ_API_KEY=your_groq_api_key_here
TRANSCRIPTION_API_KEY=your_transcription_api_key_here

# Option 2: OpenAI Whisper API
OPENAI_API_KEY=your_openai_api_key_here


# Summarization API
# For Groq (free tier available)
GROQ_LLM_API_KEY=your_groq_api_key_here
LLM_API_KEY=your_llm_api_key_here

# For Gemini (Google AI)
GEMINI_API_KEY=your_gemini_api_key_here

# For OpenRouter (free tier available)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Vercel KV Database
DATABASE_URL=your_database_url_here
KV_URL=your_kv_database_url
KV_REST_API_URL=your_kv_rest_api_url
KV_REST_API_TOKEN=your_kv_rest_api_token
KV_REST_API_READ_ONLY_TOKEN=your_kv_rest_api_read_only_token

# Feature Flags
USE_KV_DATABASE=true
